{
  "name": "cmd4bun",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "cmd.check": "./src/check.ts",
    "cmd.commit": "./src/commit.ts",
    "cmd.feishu": "./src/feishu.ts",
    "cmd.skills": "./src/skills.ts"
  },
  "scripts": {
    "build": "bun run build:check && bun run build:commit && bun run build:feishu && bun run build:skills && rm -f .*.bun-build",
    "build:check": "bun build ./src/check.ts --compile --outfile ./bin/cmd.check",
    "build:commit": "bun build ./src/commit.ts --compile --outfile ./bin/cmd.commit",
    "build:feishu": "bun build ./src/feishu.ts --compile --outfile ./bin/cmd.feishu",
    "build:skills": "bun build ./src/skills.ts --compile --outfile ./bin/cmd.skills",
    "start": "bun run src/commit.ts",
    "feishu": "bun run src/feishu.ts",
    "lint": "eslint"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/bun": "latest",
    "@types/eslint__js": "^9.14.0",
    "eslint": "^10.4.1",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2"
  }
}